# === Deployment (Pflicht) ===
APP_SLUG=knora
WEB_PORT=3000
FRONTEND_PORT=3084

# === Datenbank ===
DB_USER=knora
DB_PASSWORD=changeme
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@knora-db:5432/knora

# === App ===
JWT_SECRET=<generiere mit: openssl rand -base64 32>

# === Admin Credentials ===
# ADMIN_EMAIL=admin@knora.app
# ADMIN_PASSWORD=changeme
# ADMIN_NAME=Admin

# === Parser (optional) ===
# Nur nötig wenn PDF/DOCX geparsed werden soll
# PARSER_URL=http://parser:8000/parse

# === LLM Provider (Beispiel) ===
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
